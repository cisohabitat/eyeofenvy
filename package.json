{
  "name": "eyeofenvy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Eye of Envy — a locally-hosted, Eye of the Beholder-inspired 3D dungeon crawler.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.{ts,css}\""
  },
  "dependencies": {
    "@babylonjs/core": "^7.54.0",
    "@babylonjs/materials": "^7.54.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
